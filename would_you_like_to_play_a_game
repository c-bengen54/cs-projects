def run_tobias_battle(final_form=False):
    sep()
    slowprint_glitch("FINAL BATTLE: TOBIAS", "cyan", 0.04, 0.08)
    boss_health = 500 if final_form else 350
    player_health = player["health"]
    boss_attack = 14 if final_form else 10

    while boss_health > 0 and player_health > 0:
        sep()
        slowprint(color_text(f"Your HP: {player_health} | Tobias's HP: {boss_health}", "yellow"))
        action = input("Choose your action (attack / dodge / run): ").strip().lower()

        if action == "attack":
            damage = max(1, player["attack"] + random.randint(-2, 6))
