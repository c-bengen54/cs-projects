#========= Main Gameplay Loop =========
def gameplay():

    #Initialize Game State
    log_restored = False 
    command_tracker = {}
    sep()
    slowprint(color_text("You find yourself in the lobby of the arcade. Your only company being the flickering lights and broken machines around you.", "italic"), 0.1)
    pause()
    slowprint(color_text("Look around, examine, and do whatever you can to escape", "italic"), 0.1)
    pause()

    current_room = player["location"]

    while True:
        sep()
        
        # Check for Game Over
        if not player["alive"]:
            slowprint(color_text("\nYou have given into the arcade...", "red"), 0.1)
            slowprint(color_text("BAD ENDING", "red"), 0.1)
            sep()
            break
        
        #Get Player Command
        command = input(color_text("> What would you like to do? (move / examine / inventory / help / look / map /interact): ", "yellow")).strip().lower()

        #Look around the room
        if command in ["scan", "look"]:
            describe_room(current_room) 
            track_command(current_room, "look", command_tracker)

        #View Map
        elif command == "map":
            slowprint(color_text("\n===== MAP =====", "cyan"), 0.04)
            for room, data in locations.items():
                status = []
                if room in player["visited_rooms"]:
                    status.append("visited")
                if data["is_locked"]:
                    status.append("locked")
                else:
                    status.append("unlocked")
                if data.get("requires_power"):
                    status.append("power required")
                else:
                    status.append("no power needed/powered")
                slowprint(f"- {room}: {', '.join(status)}\n", 0.02)
            track_command(current_room, "map", command_tracker)
        
        #Interact with POI's in the room
        elif command == "interact":
            slowprint("\nInteract with what? Specify an object to interact with.", 0.02)
            raw = input(color_text("\n> Object to interact with: ", "yellow")).strip().lower()

            # create normalized variants to compare against keys in locations[...]["objects"]
            norm_us, norm_nospace, norm_space = normalize_obj_name(raw)

            objs = locations[current_room].get("objects", {})
        

            # Attempt to find the object key (accept multiple forms)
            matched_key = None
            for key in objs.keys():
                if key == norm_us or key == norm_nospace or key == norm_space or key == raw:
                    matched_key = key
                    break

            # Fallback: allow partial matching (e.g., "ticket" matches "ticket_machine")
            if matched_key is None:
                for key in objs.keys():
                    if raw in key or raw in key.replace("_", " "):
                        matched_key = key
                        break

            if matched_key is None:
                slowprint("There's nothing like that here.", 0.02)
                continue

            obj = objs[matched_key]

            #Object interaction logic
            if matched_key == "prize counter" and current_room == "lobby":
                if "key" not in player["inventory"]:
                    slowprint("\nYou search the prize counter and find a small key hidden behind some old prizes.", 0.02)
                    player["inventory"].append("key")
                    slowprint(color_text("\nYou obtained: key", "green"))
                else:
                    slowprint("\nYou've already taken the key from here.", 0.02)
                continue

            if matched_key == "cleaning cart" and current_room == "lobby":
                slowprint("\nYou rummage through the cleaning cart but find nothing useful, but you see an interesting note on the side. You think of [examining] it but move on..", 0.02)
                continue

            if matched_key == "ticket machine" and current_room == "lobby":
                if "ticket" not in player["inventory"]:
                    slowprint("\nThe ticket machine is broken beyond repair, but you take a ticket from it, half sticking out", 0.02)
                    player["inventory"].append("ticket")
                    slowprint(color_text("\nYou obtained: ticket", "green"))
                    continue
                else:
                    slowprint("\nThe ticket machine has nothing left to give.", 0.02)
                continue

            if matched_key == "cafeteria table" and current_room == "cafeteria":
                if "keycard" not in player["inventory"]:
                    slowprint(color_text("\nLooks like theres a keycard here, dont mind if I do...", "blue"), 0.02)
