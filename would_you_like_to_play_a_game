#========= Main Gameplay Loop =========
def lobby_gameplay():
    sep()
    slowprint(color_text("You find yourself in the lobby of the arcade. Your only company being the flickering lights and broken machines around you.", "italic"), 0.1)
    pause()
    slowprint(color_text("You need to find your friends and escape..", "italic"), 0.1)
    pause()
    slowprint(color_text("Look around, examine, and do whatever you can to escape", "italic"), 0.1)
    pause()

    current_room = player["location"]

    while True:
        sep()
        command = input(color_text("> What would you like to do? (move/examine/inventory/help/look): ", "yellow")).strip().lower()

        if command in ["scan", "look"]:
            describe_room(current_room)
        
        elif command.startswith("examine "):
            obj_name = command.replace("examine ", "")
            examine_object(current_room, obj_name)
        
        elif command.startswith("move "):
            target = command.replace("move ", "")
            current_room = move_to_room(current_room, target, player["inventory"])
        
        elif command == "inventory":
            slowprint("I have..: " + ", ".join(player["inventory"]) if player["inventory"] else "Your inventory is empty.", 0.02)

        elif command == "help":
            slowprint("I can... move [location], examine [object], inventory, look/scan, help", 0.02)

        elif command == "quit":
            slowprint("You decide to give up and give into the darkness around you..", 0.02)
            slowprint(color_text("BAD ENDING","red"), 0.1)
            break
        
        else:
            slowprint("Im not sure thats something I can do..", 0.02)

#========= Room and Object Logic =========
def describe_room(room):
    data = locations[room]
    slowprint(f"You are in the {room}.", 0.02)
    slowprint(data["description"], 0.02)
    pause()
    if "objects" in data:
        slowprint("You notice..", 0.04)
        for obj in data["objects"]:
            slowprint(f"- {obj}: {data['objects'][obj]['description']}", 0.02)

def examine_object(room, obj_name):
    room_data = locations[room]
    if "objects" not in room_data or obj_name not in room_data["objects"]:
        slowprint("Theres nothing like that here.", 0.02)
        return
    
    obj = room_data["objects"][obj_name]
    slowprint(color_text(f"{obj_name.upper()}:", "bold"))
    slowprint(obj["description"])
    if obj["interactable"] and obj["puzzle"]:
        slowprint(color_text("It seems interactive...", "italic"))
        play = input("Inspect further? (y/n): ").lower()
        if play == "y":
            run_puzzle(obj["puzzle"])
    
#========= Puzzle Dispatcher =========
def run_puzzle(puzzle_name):
    puzzles = {
        "generator": puzzle_generator,
        "syntax": puzzle_syntax,
        "signal_interrupt": puzzle_interrupt,
        "file_restore": puzzle_file_restore,
        "eof_input": puzzle_eof,
        "corrupted_boot": puzzle_bootloader
    }

    if puzzle_name in puzzles:
        puzzles[puzzle_name]()
    else:
        slowprint("Im over thinking this..", 0.02)

#Individual Puzzle Definitions
def puzzle_generator():
    sep()
    slowprint_glitch(">>> POWER GENERATOR TERMINAL <<<", "cyan", 0.02, 0.08)
    pause()
    slowprint("SYSTEM STATUS: OFFLINE", 0.03)
    slowprint("You see 3 voltage dials. Each needs to sum to 100 volts exactly.")
    pause()

    voltages = []
    for i in range(3):
        try:
            v = int(input(f"Set voltage dial {i+1}: "))
            voltages.append(v)
        except ValueError:
            print("That's not a valid number, what am I doing..?")
            return puzzle_generator()
    total = sum(voltages)

    if total == 100:
        flicker_text(color_text("POWER RESTORED", "green"), 6, 0.15)
        slowprint("Lights hum back to life across the arcade...")
        locations["control_room"]["is_locked"] = False
    else:
        slowprint(color_text("VOLTAGE INSTABILITY DETECTED: SYSTEM SHUTTING DOWN...", "red"))
        fake_glitch_sequence()


def puzzle_syntax():
    sep()
    slowprint("You find an old CRT monitor showing broken Python code:")
    print(color_text('for i in range(5)\n    print("Hello Arcade")', "yellow"))
    pause()
    guess = input("You feel an urge to fix the code and type it correctly: ").strip()

    if guess == 'for i in range(5): print("Hello Arcade")' or guess == 'for i in range(5):\n    print("Hello Arcade")':
        slowprint(color_text("CODE COMPILED SUCCESSFULLY.", "green"))
        slowprint("You hear a nearby door unlocks with a loud click...")
        locations["backroom"]["is_locked"] = False
    else:
        slowprint(color_text("SYNTAX ERROR: TRY AGAIN LATER...", "red"))


def puzzle_interrupt():
    sep()
    slowprint("The terminal hums: a strange program runs endlessly...")
    slowprint("You see this on screen:")
    print(color_text("while True:\n    print('RUNNING...')", "yellow"))
    pause()
    slowprint(color_text("You feel the urge to 'INTERRUPT' it somehow...", "italic"))

    try:
        while True:
            print("RUNNING...", end="\r")
            time.sleep(0.3)
    except KeyboardInterrupt:
        slowprint(color_text("\nPROGRAM INTERRUPTED. ACCESS GRANTED.", "green"))
        slowprint("A door unlocks as the fans die down.")
        locations["arcade_room_floor"]["is_locked"] = False


def puzzle_file_restore():
    sep()
    slowprint("You find a broken log file named system_log.txt")
    with open("system_log.txt", "w") as f:
        f.write("ERROR###POWER###CORRUPTED###\n")

    slowprint("A message reads: 'Restore log integrity to continue.'")
    guess = input("Enter the restored text line: ")

    if guess.lower().strip() == "power restored successfully":
        with open("system_log.txt", "w") as f:
            f.write("POWER RESTORED SUCCESSFULLY\n")
        slowprint(color_text("LOG REPAIRED. ACCESS UNLOCKED.", "green"))
    else:
        slowprint(color_text("The screen prints 'RESTORATION FAILED' as the system hums ominously...", "red"))


def puzzle_eof():
    sep()
    slowprint("You see a message: 'Awaiting user input to terminate connection...'")
    slowprint(color_text("Hint: Sometimes silence says more than words...", "italic"))
    try:
        while True:
            line = input(">> ")
            if line.lower() == "exit":
                slowprint("Manual exit not accepted.")
    except EOFError:
        slowprint(color_text("\nCONNECTION TERMINATED.", "green"))
        slowprint("The terminal powers off.")
    except KeyboardInterrupt:
        slowprint(color_text("\WRONG INPUT TYPE.", "RED"))


def puzzle_bootloader():
    sep()
    slowprint_glitch(">>> BOOT SECTOR CORRUPTED <<<", "red", 0.03, 0.1)
    pause()
    slowprint("Repair sequence initiated...")
    time.sleep(1)
    slowprint("TYPE 'REPAIR' WHEN PROMPTED TO STABILIZE SECTORS.")
    for i in range(5):
        sys.stdout.write(glitch_text(f"Sector {i+1}: STABILIZING...\n", 0.2))
        time.sleep(random.uniform(0.5, 1.2))
        inp = input("TYPE NOW: ").strip().upper()
        if inp != "REPAIR":
            slowprint(color_text("SECTOR DESTABALIZED, BOOT REQUIRES RESTART...", "red"))
            return
    slowprint(color_text("ALL SECTORS STABILIZED. SYSTEM BOOTED SUCCESSFULLY.", "green"))


