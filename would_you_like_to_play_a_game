#Utility: Simulate a Dice Roll
def dice_roll():
    return random.randint(1, 20)

#Utility: Separator Line
def sep():
    print("\n" + "-" * 60 + "\n")

#Utility: Short Pause
def pause(sec = 0.6):
    time.sleep(sec)

#Utility: Typewriter Style Printing
def slowprint(text, delay = 0.02):
    for ch in text:
        print(ch, end = "", flush = True)
        time.sleep(delay)
    print()

#Utility: Dynamic Typewriter Style Printing
def auto_slowprint(text):
    base_delay = 0.3
    delay = base_delay / max(len(text)/50, 1)
    for ch in text:
        print(ch, end = "", flush = True)
        time.sleep(min(delay, 0.05))
    print()

#Utility: Glitched Typewriter Style Printing
def slowprint_glitch(text, color = "end", delay = 0.02, intensity = 0.02):
    for ch in text:
        if random.random() < intensity and ch.isalpha():
            print(color_text(random.choice(["@", "#", "$", "%", "&", "*"]), color), end = "", flush  = True)
        else:
            print(color_text(ch, color), end = "", flush = True)
        time.sleep(delay)
    print()

#Utility: Glitched Text Printer
def glitch_text(text, intensity = 0.02): #REMEMBER TO SURROUND BY A PRINT STATEMENT
    glitched = ""
    for ch in text:
        if random.random() < intensity and ch.isalpha():
            glitched += random.choice(["@", "#", "$", "%", "&", "*"])
        else:
            glitched += ch
    return glitched

#Utility: Flickering Text
def flicker_text(text, times = 5, delay = 0.2):
    for i in range(times):
        print("\033c", end = "", flush = True)
        time.sleep(delay/2)
        print(text, flush = True)
        time.sleep(delay/2)
    print()

#Utility: Fake Glitch Sequence
def fake_glitch_sequence():
    slowprint(color_text(">>> SYSTEM REBOOTING <<<", "red"), 0.04)
    pause()
    for i in range(4):
        print(glitch_text("LOADING MEMORY MODULE...", 0.4))
        time.sleep(0.4)
    flicker_text(color_text(">>> ACCESS GRANTED <<<", "green"), 5, 0.15)

#Utility: ANSI Color Helper
def color_text(text, color = "end"):
    colors = {
        "bold": "\033[1m",
        "red": "\033[31m",
        "green": "\033[32m",
        "yellow": "\033[33m",
        "blue": "\033[34m",
        "magenta": "\033[35m",
        "cyan": "\033[36m",
        "white": "\033[37m",
        "italic": "\033[3m",
        "end": "\033[0m"
        }
    return f"{colors.get(color, '')}{text}{colors['end']}"

#Movement and Lock Logic
def move_to_room(current_room, target_room, inventory):
    global player, locations

    if target_room not in locations[current_room]["connected"]:
        print("You can't go from there to here")
        return current_room

    room_data = locations[target_room]
    if room_data["is_locked"]:
        if room_data["required_item"] in inventory:
            slowprint(f"You use the {room_data['required_item']} to unlock the door.", 0.02)
            room_data["is_locked"] = False
        else:
            slowprint("The door is locked, you need something to open it.", 0.02)
            return current_room
    player["location"] = target_room
    slowprint(f"You enter the {target_room}.", 0.02)
    slowprint(room_data["description"], 0.02)
    return target_room

